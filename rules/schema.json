{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/wp-plugin-compliance-rule.schema.json",
  "title": "WordPress Plugin Compliance Rule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "summary",
    "category",
    "severity",
    "origin",
    "coverage",
    "official_sources",
    "detection",
    "guidance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "security",
        "code-quality",
        "file-structure",
        "readme",
        "metadata",
        "policy",
        "plugin-repo",
        "performance",
        "lifecycle"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "advisory",
        "info"
      ]
    },
    "origin": {
      "type": "string",
      "enum": [
        "official-handbook",
        "official-plugin-check",
        "project-heuristic",
        "field-experience"
      ]
    },
    "coverage": {
      "type": "string",
      "enum": [
        "implemented",
        "heuristic",
        "delegated",
        "docs-only",
        "planned"
      ]
    },
    "official_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "regex",
            "glob",
            "metadata",
            "composite",
            "external-tool",
            "manual"
          ]
        },
        "file_globs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pattern_mode": {
          "type": "string",
          "enum": [
            "fixed",
            "extended-regex"
          ]
        },
        "metadata_check": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "external_tool": {
          "type": "string"
        }
      }
    },
    "guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "why_it_matters",
        "fix"
      ],
      "properties": {
        "why_it_matters": {
          "type": "string",
          "minLength": 1
        },
        "fix": {
          "type": "string",
          "minLength": 1
        },
        "false_positive_risk": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
